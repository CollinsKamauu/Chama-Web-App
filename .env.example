# Copy to `.env` and fill in. Never commit `.env`.

# ─── Database (Prisma) ───────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?schema=public"

# ─── M-Pesa Daraja (server only — used by `npm run dev:mpesa-api`) ─────────────
MPESA_CONSUMER_KEY=""
MPESA_CONSUMER_SECRET=""
MPESA_INITIATOR_NAME=""
MPESA_SECURITY_CREDENTIAL=""
MPESA_B2C_SHORTCODE=""
MPESA_ENVIRONMENT="production"

# Must be HTTPS and publicly reachable for production (use ngrok for local dev).
MPESA_B2C_RESULT_URL="https://your-backend.example.com/api/mpesa/b2c/result"
MPESA_B2C_QUEUE_TIMEOUT_URL="https://your-backend.example.com/api/mpesa/b2c/timeout"

MPESA_ACCOUNT_BALANCE_RESULT_URL="https://your-backend.example.com/api/mpesa/webhooks/account-balance"
MPESA_ACCOUNT_BALANCE_QUEUE_TIMEOUT_URL="https://your-backend.example.com/api/mpesa/b2c/timeout"

MPESA_TRANSACTION_STATUS_RESULT_URL="https://your-backend.example.com/api/mpesa/txn-status/result"
MPESA_TRANSACTION_STATUS_QUEUE_TIMEOUT_URL="https://your-backend.example.com/api/mpesa/b2c/timeout"

# Optional: show a balance in the UI before the first AccountBalance callback writes the cache.
# MPESA_WORKING_BALANCE_FALLBACK_KES="469560"

MPESA_API_PORT="8787"

# Vite dev: proxy /api/mpesa → this URL
# VITE_MPESA_API_PROXY_TARGET="http://127.0.0.1:8787"
